# Configuração do LLM via OpenRouter.
# Copie este arquivo para `.env` e preencha a sua chave.

# Chave de API do OpenRouter (obrigatória para usar --use-llm)
OPENROUTER_API_KEY=sk-or-...

# Modelo a ser usado (opcional; padrão abaixo)
OPENROUTER_MODEL=openai/gpt-4o-mini

# Endpoint base do OpenRouter (opcional)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cabeçalhos opcionais recomendados pelo OpenRouter para identificar a aplicação
OPENROUTER_APP_TITLE=MOP Generator
OPENROUTER_APP_URL=
